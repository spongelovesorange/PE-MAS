# PE-MAS runtime configuration

# App mode:
# - studio: serve the full PE-MAS Studio UI and MAS workflow
# - api: run only API routers for external integrations
# - auto: prefer Studio, fall back to API if local UI dependencies are unavailable
PE_MAS_APP_MODE=studio

# Server
PE_MAS_HOST=<bind-host>
PE_MAS_PORT=<port>
PE_MAS_LOG_LEVEL=info
PE_MAS_ACCESS_LOG=0

# Runtime artifacts. Keep this ignored/local.
PE_MAS_RUNTIME_DIR=.pe_mas_runtime

# Quiet output controls. Leave these off for product/demo use.
PE_MAS_TRACE_STREAM=0
PE_MAS_VERBOSE_STDIO=0
PE_MAS_WARN_ON_FALLBACK=0

# LLM/provider config. Required for full MAS reasoning paths.
# Set model-provider credentials locally. Do not commit actual values.
# PE_MAS_LLM_CREDENTIAL=<provider-credential>
# PE_MAS_LLM_ENDPOINT=<optional-provider-endpoint>

# Optional local web-search fallback. The default uses the product web-search skill first.
PE_MAS_ENABLE_LOCAL_WEB_FALLBACK=0

# PLECS integration
PE_MAS_PLECS_BACKEND=auto
# PLECS_RPC_URL=<plecs-rpc-url>

# OpenMagnetics helper
PE_MAS_OPENMAGNETICS_MODE=auto
